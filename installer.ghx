"""
This component installs the Ladybug Tools core libraries to the ladybug_tools
installation folder using the Python installation.
_
It also installs all of the grasshopper components to:
C:\Users\%USERNAME%\AppData\Roaming\Grasshopper\UserObjects
(or the equivalent location for UserObjects on Mac)
_
It also installs the lbt_grasshopper_samples to:
ladybug_tools\resources\samples
_
It also installs standards to:
ladybug_tools\resources\standards
-

    Args:
        _install: Set to True to install Ladybug Tools on your machine.

    Returns:
        Vviiiiiz!: !!!
"""

ghenv.Component.Name = 'LB Installer'
ghenv.Component.NickName = 'LBInstall'
ghenv.Component.Message = '1.10.0'
ghenv.Component.Category = 'Ladybug'
ghenv.Component.SubCategory = '5 :: Version'
ghenv.Component.AdditionalHelpFromDocStrings = '0'

import os
