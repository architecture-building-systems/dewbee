import os
import shutil
import zipfile
import subprocess
import System.Net
import System.Windows.Forms
import Rhino

from Grasshopper.Folders import UserObjectFolders
from Grasshopper.Kernel import GH_RuntimeMessageLevel as Message


# -----------------------------------------------------------------------------
# CONFIG
# -----------------------------------------------------------------------------

PYPI_PACKAGE = "dewbee"
PYPI_IMPORT_NAME = "dewbee"

GITHUB_OWNER = "architecture-building-systems"
GITHUB_REPO = "dewbee_main"

# relative path inside the downloaded repo zip
REPO_GHUSER_SUBFOLDER = os.path.join("grasshopper", "user_objects")

# target folder name inside Grasshopper UserObjects
GHUSER_TARGET_FOLDER_NAME = "dewbee"

CUSTOM_ENV = os.environ.copy()
CUSTOM_ENV["PYTHONHOME"] = ""


# -----------------------------------------------------------------------------
# UI HELPERS
# -----------------------------------------------------------------------------

def give_warning(message):
    ghenv.Component.AddRuntimeMessage(Message.Warning, str(message))


def give_error(message):
    ghenv.Component.AddRuntimeMessage(Message.Error, str(message))


def give_popup_message(message, window_title=""):
    icon = System.Windows.Forms.MessageBoxIcon.Information
    buttons = System.Windows.Forms.MessageBoxButtons.OK
    Rhino.UI.Dialogs.ShowMessageBox(str(message), window_title, buttons, icon)


# -----------------------------------------------------------------------------
# FILE HELPERS
# -----------------------------------------------------------------------------

def preparedir(target_dir, remove_content=False):
    """Create folder if missing. Optionally clear content if it exists."""
    if os.path.isdir(target_dir):
        if remove_content:
            nukedir(target_dir, rmdir=False)
        return True
    try:
        os.makedirs(target_dir)
        return True
    except Exception as e:
        raise IOError("Failed to create directory '{}': {}".format(target_dir, e))


def nukedir(target_dir, rmdir=False):
    """Delete contents of a directory."""
    d = os.path.normpath(target_dir)
    if not os.path.isdir(d):
        return

    for f in os.listdir(d):
        if f in (".", ".."):
            continue
        path = os.path.join(d, f)
        if os.path.isdir(path):
            nukedir(path, rmdir=True)
        else:
            try:
                os.remove(path)
            except Exception as e:
                print("Failed to remove file '{}': {}".format(path, e))

    if rmdir:
        try:
            os.rmdir(d)
        except Exception:
            pass


def copy_file_tree(source_folder, dest_folder, overwrite=True):
    """Recursively copy a folder tree."""
    if not os.path.isdir(source_folder):
        raise IOError("Source folder does not exist: {}".format(source_folder))

    if not os.path.isdir(dest_folder):
        os.makedirs(dest_folder)

    for name in os.listdir(source_folder):
        src_path = os.path.join(source_folder, name)
        dst_path = os.path.join(dest_folder, name)

        if os.path.isfile(src_path):
            if overwrite and os.path.isfile(dst_path):
                os.remove(dst_path)
            shutil.copyfile(src_path, dst_path)

        elif os.path.isdir(src_path):
            if overwrite and os.path.isdir(dst_path):
                nukedir(dst_path, rmdir=True)
            if not os.path.isdir(dst_path):
                os.makedirs(dst_path)
            copy_file_tree(src_path, dst_path, overwrite=overwrite)


def remove_dist_info_files(directory, startswith_name=None):
    """Remove .dist-info folders, optionally filtering by prefix."""
    if not os.path.isdir(directory):
        return

    for name in os.listdir(directory):
        if not name.endswith(".dist-info"):
            continue
        if startswith_name is not None:
            if not name.lower().startswith(startswith_name.lower().replace("-", "_")):
                continue
        full_path = os.path.join(directory, name)
        print("Removing dist-info folder: {}".format(full_path))
        nukedir(full_path, rmdir=True)


# -----------------------------------------------------------------------------
# DOWNLOAD HELPERS
# -----------------------------------------------------------------------------

def download_file_by_name(url, target_folder, file_name, mkdir=False):
    """Download a file to a target folder."""
    if not os.path.isdir(target_folder):
        if mkdir:
            preparedir(target_folder)
        else:
            raise IOError("Target folder does not exist: {}".format(target_folder))

    file_path = os.path.join(target_folder, file_name)

    try:
        System.Net.ServicePointManager.SecurityProtocol = \
            System.Net.SecurityProtocolType.Tls12
    except AttributeError:
        if url.lower().startswith("https"):
            print("This system may lack TLS 1.2 support for https downloads.")

    client = System.Net.WebClient()
    try:
        client.DownloadFile(url, file_path)
    except Exception as e:
        raise Exception("Download failed:\n{}".format(e))

    return file_path


def unzip_file(source_file, dest_dir):
    """Unzip a file to a target folder."""
    if not os.path.isfile(source_file):
        raise IOError("Zip file not found: {}".format(source_file))
    preparedir(dest_dir)

    with zipfile.ZipFile(source_file, "r") as zf:
        zf.extractall(dest_dir)


def build_github_zip_url(owner, repo, ref):
    """
    Build GitHub archive URL.
    GitHub supports archive/refs/heads/&lt;branch&gt;.zip and archive/refs/tags/&lt;tag&gt;.zip.
    We try tag-style if ref starts with 'v', otherwise branch-style.
    """
    if ref and ref.startswith("v"):
        return "https://github.com/{}/{}/archive/refs/tags/{}.zip".format(owner, repo, ref)
    return "https://github.com/{}/{}/archive/refs/heads/{}.zip".format(owner, repo, ref or "main")


def expected_unzipped_repo_folder(base_dir, repo, ref):
    """
    GitHub usually extracts to:
    - repo-branch
    - repo-tag_without_prefix? No, usually repo-&lt;tag&gt;
    """
    return os.path.join(base_dir, "{}-{}".format(repo, ref or "main"))


# -----------------------------------------------------------------------------
# LBT / PYTHON HELPERS
# -----------------------------------------------------------------------------

def get_lbt_python():
    """Get Ladybug Tools python executable and site-packages path."""
    try:
        from honeybee.config import folders as hb_folders
    except Exception as e:
        raise ImportError(
            "Failed to import honeybee.config.folders.\n"
            "Ladybug Tools / Honeybee must already be installed.\n{}".format(e)
        )

    py_exe = hb_folders.python_exe_path
    py_site = hb_folders.python_package_path

    if not py_exe or not os.path.isfile(py_exe):
        raise IOError("Could not find Ladybug Tools python executable:\n{}".format(py_exe))
    if not py_site or not os.path.isdir(py_site):
        raise IOError("Could not find Ladybug Tools site-packages:\n{}".format(py_site))

    return py_exe, py_site


def run_pip_install(python_exe, package_name, version=None, target=None, env=None):
    """Install or update a package with pip."""
    if env is None:
        env = os.environ

    requirement = package_name if not version else "{}=={}".format(package_name, version)

    cmds = [python_exe, "-m", "pip", "install", requirement, "--upgrade"]
    if target:
        cmds.extend(["--target", target])

    print("- " * 30)
    print("Running pip command:")
    print(" ".join(cmds))

    use_shell = True if os.name == "nt" else False
    process = subprocess.Popen(
        cmds,
        shell=use_shell,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env
    )
    stdout, stderr = process.communicate()

    try:
        stdout = stdout.decode("utf-8")
    except Exception:
        stdout = str(stdout)

    try:
        stderr = stderr.decode("utf-8")
    except Exception:
        stderr = str(stderr)

    return process.returncode, stdout, stderr


def package_dist_info_exists(site_packages, import_name, version=None):
    """
    Check whether a package appears installed by searching for:
    dewbee-0.1.0.dist-info or at least dewbee-*.dist-info.
    """
    if not os.path.isdir(site_packages):
        return False

    prefix = import_name.replace("-", "_").lower() + "-"
    suffix = ".dist-info"

    for name in os.listdir(site_packages):
        low = name.lower()
        if low.startswith(prefix) and low.endswith(suffix):
            if version is None:
                return True
            if low == "{}{}.dist-info".format(prefix, version.lower()):
                return True
    return False


# -----------------------------------------------------------------------------
# GH USER OBJECT INSTALL
# -----------------------------------------------------------------------------

def get_ghuser_target_folder():
    if not UserObjectFolders or len(UserObjectFolders) == 0:
        raise IOError("Could not find Grasshopper UserObjects directory.")
    base = UserObjectFolders[0]
    target = os.path.join(base, GHUSER_TARGET_FOLDER_NAME)
    return target


def install_ghuser_objects_from_repo_zip(owner, repo, ref, temp_root, gh_target_folder):
    """
    Download repo zip, extract, and copy grasshopper/user_objects/* to GH UserObjects/dewbee.
    """
    url = build_github_zip_url(owner, repo, ref)
    zip_name = "{}_{}.zip".format(repo, ref or "main")
    zip_path = None
    extracted_repo_dir = None

    print("- " * 30)
    print("Downloading Grasshopper components from GitHub:")
    print(url)

    try:
        zip_path = download_file_by_name(url, temp_root, zip_name, mkdir=True)
        print("Downloaded zip to:\n{}".format(zip_path))

        unzip_file(zip_path, temp_root)
        extracted_repo_dir = expected_unzipped_repo_folder(temp_root, repo, ref or "main")

        if not os.path.isdir(extracted_repo_dir):
            # fallback: search for the extracted folder
            candidates = []
            for name in os.listdir(temp_root):
                full = os.path.join(temp_root, name)
                if os.path.isdir(full) and name.startswith(repo + "-"):
                    candidates.append(full)
            if len(candidates) == 1:
                extracted_repo_dir = candidates[0]

        if not os.path.isdir(extracted_repo_dir):
            raise IOError("Could not locate extracted repo folder inside:\n{}".format(temp_root))

        source_ghuser_folder = os.path.join(extracted_repo_dir, REPO_GHUSER_SUBFOLDER)
        if not os.path.isdir(source_ghuser_folder):
            raise IOError(
                "Could not find expected GH user objects folder in repo:\n{}".format(source_ghuser_folder)
            )

        print("Copying .ghuser files from:\n{}\nTo:\n{}".format(source_ghuser_folder, gh_target_folder))
        preparedir(gh_target_folder, remove_content=True)
        copy_file_tree(source_ghuser_folder, gh_target_folder, overwrite=True)

    finally:
        try:
            if zip_path and os.path.isfile(zip_path):
                os.remove(zip_path)
        except Exception:
            pass

        try:
            if extracted_repo_dir and os.path.isdir(extracted_repo_dir):
                nukedir(extracted_repo_dir, rmdir=True)
        except Exception:
            pass


# -----------------------------------------------------------------------------
# MAIN INSTALL
# -----------------------------------------------------------------------------

def install_dewbee(dewbee_version=None, github_ref=None):
    py_exe, py_site = get_lbt_python()

    print("Ladybug Tools Python executable:")
    print(py_exe)
    print("Ladybug Tools site-packages:")
    print(py_site)

    # 1) pip install dewbee into LBT Python
    print("- " * 30)
    print("Installing Dewbee Python package...")

    returncode, stdout, stderr = run_pip_install(
        python_exe=py_exe,
        package_name=PYPI_PACKAGE,
        version=dewbee_version,
        target=None,  # install directly into LBT env
        env=CUSTOM_ENV
    )

    print(stdout)
    if stderr:
        print(stderr)

    if returncode != 0:
        raise Exception("pip install failed for '{}'.\n{}".format(PYPI_PACKAGE, stderr))

    if not package_dist_info_exists(py_site, PYPI_IMPORT_NAME, dewbee_version):
        print("Warning: could not verify exact .dist-info folder for Dewbee.")
        print("Proceeding anyway because some pip installs can still succeed with variant metadata names.")

    # 2) install GH user objects from GitHub
    home_folder = os.getenv("HOME") or os.path.expanduser("~")
    temp_root = os.path.join(home_folder, "dewbee_installer_temp")
    gh_target = get_ghuser_target_folder()

    install_ghuser_objects_from_repo_zip(
        owner=GITHUB_OWNER,
        repo=GITHUB_REPO,
        ref=github_ref or "main",
        temp_root=temp_root,
        gh_target_folder=gh_target
    )

    # cleanup temp folder root if empty / remaining
    if os.path.isdir(temp_root):
        try:
            nukedir(temp_root, rmdir=True)
        except Exception:
            pass

    # 3) success
    success_lines = [
        "Dewbee has been successfully installed.",
        "Python package installed into Ladybug Tools Python.",
        "Grasshopper user objects installed to:",
        gh_target,
        "",
        "RESTART RHINO to load the new components and library."
    ]

    success_msg = "\n".join(success_lines)
    print(success_msg)
    give_popup_message(success_msg, "Dewbee Installation Successful")


# -----------------------------------------------------------------------------
# EXECUTION
# -----------------------------------------------------------------------------

if _install:
    try:
        install_dewbee(
            dewbee_version=_dewbee_ver if _dewbee_ver else None,
            github_ref=_github_ref if _github_ref else "main"
        )
    except Exception as e:
        msg = "Dewbee installation failed:\n{}".format(e)
        print(msg)
        give_error(msg)
else:
    print("Set _install to True to install Dewbee.")
    print("Optional:")
    print("  _dewbee_ver  -&gt; specific PyPI version, eg. 0.1.0")
    print("  _github_ref  -&gt; GitHub branch or tag, eg. main or v0.1.0")</item>
