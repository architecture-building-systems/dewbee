                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Update the version of all ghuser objects available in Grasshopper\UserObjects\dewbee 
based on dewbee.__version__. Then, save them to the repository as .py and .ghuser, 
and update the local .ghuser files. Anything that has "DB" will be saved. 

This version:
. reads dewbee.__version__
. updates ghenv.Component.Message in component code
. cleans repo
. writes updated .py files
. writes updated .ghuser files by modifying the original user object
. updates .ghuser files in local directory (components shown in GH's tab)
-

    Args:
        _run: RUN IT BABY!
"""

import os
import Grasshopper.Kernel as ghK

ghenv.Component.Name = '__DB Save Compos'
ghenv.Component.NickName = 'SaveCompos'
ghenv.Component.Message = 'dev'
ghenv.Component.Category = 'Dewbee'
ghenv.Component.SubCategory = "0 :: Miscellaneous"

# Turn off the "old" tag
try:
    import ghpythonlib as ghlib
    c = ghlib.component._get_active_component()
    c.ToggleObsolete(False)
except Exception:
    pass

# Read Dewbee version
try:
    import dewbee
    reload(dewbee)
    DEWBEE_VERSION = dewbee.__version__
    ghenv.Component.Message = DEWBEE_VERSION
except Exception as e:
    raise ImportError("Failed to import dewbee.__version__:\n\t{}".format(e))

# Import ladybug dependencies
try:
    from ladybug.futil import preparedir, copy_file_tree
except Exception as e:
    raise ImportError("Failed to import dewbee.__version__:\n\t{}".format(e))

class NamespaceComponentsOntoCanvas(object):
    def __init__(self, namespace, source_dir, ghdoc):
        self.namespace = namespace
        self.source_dir = source_dir
        self.ghdoc = ghdoc
        self.compos = []

    def __enter__(self):
        print("Adding {} components to canvas...".format(self.namespace))

        for filename in os.listdir(self.source_dir):
            if filename.startswith('.'):
                continue
            if filename.startswith('__'):
                continue
            if not filename.endswith('.ghuser'):
                continue
            if not filename.startswith(self.namespace):
                continue

            source_path = os.path.join(self.source_dir, filename)
            uo = ghK.GH_UserObject(source_path)
            compo = uo.InstantiateObject()

            if compo is None:
                print("Failed to instantiate: {}".format(filename))
                continue

            self.ghdoc.AddObject(compo, False)
            self.compos.append((compo, uo, source_path))
            print("Added: {}".format(filename))

        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print("Cleaning canvas...")
        for compo, _, _ in self.compos:
            self.ghdoc.RemoveObject(compo, False)


def update_component_version(components, version):
    """Update the ghenv.Component.Message line for a list of components."""
    new_components = []

    for comp_obj in components:
        try:
            in_code = comp_obj.Code.split("\n")
            code_length = len(in_code)
            out_code = ""

            for line_count, line in enumerate(in_code):
                stripped = line.lstrip()
                indent = line[:len(line) - len(stripped)]

                if stripped.startswith("ghenv.Component.Message"):
                    line = indent + "ghenv.Component.Message = '{}'".format(version)

                if line_count != code_length - 1:
                    out_code += line + "\n"
                else:
                    out_code += line

            comp_obj.Code = out_code

            try:
                comp_obj.Message = version
            except Exception:
                pass

            new_components.append(comp_obj)

        except Exception as e:
            print('Failed to update version in "{}": {}'.format(comp_obj.Name, e))

    return new_components


def write_py_code(gh_component, target_dir):
    """Write the component code to the repo src folder."""
    if not hasattr(gh_component, "Code"):
        return

    target_path = os.path.join(target_dir, gh_component.Name + ".py")
    with open(target_path, "wb") as f:
        f.write(gh_component.Code.encode("utf-8"))

    print("Wrote code: {}".format(target_path))


def write_ghuser(original_uo, gh_component, target_dir):
    """Update the original user object with the modified component and save it."""
    target_path = os.path.join(target_dir, gh_component.Name + ".ghuser")

    original_uo.SetDataFromObject(gh_component)
    original_uo.Path = target_path

    ok = original_uo.SaveToFile()
    if not ok:
        raise IOError("Failed to save ghuser: {}".format(target_path))

    print("Wrote ghuser: {}".format(target_path))


if _run:
    ghdoc = ghenv.Component.OnPingDocument()

    local_ghuser = r"C:\Users\gzorzeto\AppData\Roaming\Grasshopper\UserObjects\dewbee"
    repo_ghuser = r"C:\Users\gzorzeto\Documents\GitHub_repos\dewbee_main\grasshopper\user_objects"
    repo_py = r"C:\Users\gzorzeto\Documents\GitHub_repos\dewbee_main\grasshopper\src"

    preparedir(repo_ghuser)
    preparedir(repo_py)

    with NamespaceComponentsOntoCanvas("DB", local_ghuser, ghdoc) as compos:
        comp_list = [compo for compo, _, _ in compos.compos]
        update_component_version(comp_list, DEWBEE_VERSION)

        for compo, uo, source_path in compos.compos:
            write_py_code(compo, repo_py)
            write_ghuser(uo, compo, repo_ghuser)
    
    # Update local ghuser folder
    preparedir(local_ghuser)
    copy_file_tree(repo_ghuser, local_ghuser)</item>
