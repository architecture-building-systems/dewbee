                        <chunk name="OutputParam" index="0">
                          <items count="6">
                            <item name="Description" type_name="gh_string" type_code="10">A hygrothermal opaque material that can be assigned to a Honeybee
Opaque construction.</item>
                            <item name="InstanceGuid" type_name="gh_guid" type_code="9">417a1c15-0f40-4fa5-bce3-05d2da1edd19</item>
                            <item name="Name" type_name="gh_string" type_code="10">mat</item>
                            <item name="NickName" type_name="gh_string" type_code="10">mat</item>
                            <item name="Optional" type_name="gh_bool" type_code="1">false</item>
                            <item name="SourceCount" type_name="gh_int32" type_code="3">0</item>
                          </items>
                          <chunks count="1">
                            <chunk name="Attributes">
                              <items count="2">
                                <item name="Bounds" type_name="gh_drawing_rectanglef" type_code="35">
                                  <X>1331</X>
                                  <Y>8305</Y>
                                  <W>29</W>
                                  <H>280</H>
                                </item>
                                <item name="Pivot" type_name="gh_drawing_pointf" type_code="31">
                                  <X>1345.5</X>
