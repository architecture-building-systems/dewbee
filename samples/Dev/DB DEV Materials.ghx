                            <item name="InstanceGuid" type_name="gh_guid" type_code="9">6a6c3c79-7f70-41ee-9351-dc2f7f050395</item>
                            <item name="Name" type_name="gh_string" type_code="10">_sorption_w_</item>
                            <item name="NickName" type_name="gh_string" type_code="10">_sorption_w_</item>
                            <item name="Optional" type_name="gh_bool" type_code="1">true</item>
