                            <item name="InstanceGuid" type_name="gh_guid" type_code="9">1bba4926-6c42-4837-8b8e-76f69ae2b894</item>
                            <item name="Name" type_name="gh_string" type_code="10">_initial_w_</item>
                            <item name="NickName" type_name="gh_string" type_code="10">_initial_w_</item>
                            <item name="Optional" type_name="gh_bool" type_code="1">true</item>
