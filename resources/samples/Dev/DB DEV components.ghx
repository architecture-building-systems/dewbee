                <chunk name="Container">
                  <items count="14">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Save all ghuser objects available in Grasshopper\UserObjects to the repository.
Anything that has "DB" will be saved. Note that if a component is erased from the 
UserObjects directory, it won't be erased from the repo. So you should manually erase
it from the repo.

    Args:
        _run: RUN IT BABY!
"""

import os
import shutil
import Grasshopper.Kernel as ghK
from GhPython.Component import ZuiPythonComponent




ghenv.Component.Name = '__DB Save Compos'
ghenv.Component.NickName = 'SaveCompos'
ghenv.Component.Message = '0.0.1'
ghenv.Component.Category = 'Dewbee'
ghenv.Component.SubCategory = "0 :: Miscellaneous"

# Turn off the "old" tag
import ghpythonlib as ghlib
c = ghlib.component._get_active_component()
c.ToggleObsolete(False)

class NamespaceComponentsOntoCanvas(object):
    def __init__(self, namespace, source_dir, ghdoc):
        self.namespace = namespace
        self.source_dir = source_dir
        self.ghdoc = ghdoc
        self.compos = []

    def __enter__(self):
        print("Adding {} components to canvas...".format(self.namespace))

        for filename in os.listdir(self.source_dir):
            if filename.startswith('.'):
                continue
            if filename.startswith('__'):
                continue
            if not filename.endswith('.ghuser'):
                continue
            if not filename.startswith(self.namespace):
                continue

            path = os.path.join(self.source_dir, filename)
            compo = ghK.GH_UserObject(path).InstantiateObject()
            self.ghdoc.AddObject(compo, False)
            self.compos.append(compo)
            print("Added: {}".format(filename))

        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print("Cleaning canvas...")
        for compo in self.compos:
            self.ghdoc.RemoveObject(compo, False)

def copy_py_code(gh_component, target_dir):
    if not hasattr(gh_component, "Code"):
        return

    target_path = os.path.join(target_dir, gh_component.Name + ".py")
    with open(target_path, "wb") as f:
        f.write(gh_component.Code.encode("utf-8"))
    print("Wrote code: {}".format(target_path))

def copy_ghuser(gh_component, source_dir, target_dir):
    src = os.path.join(source_dir, gh_component.Name + ".ghuser")
    dst = os.path.join(target_dir, gh_component.Name + ".ghuser")

    if not os.path.exists(src):
        raise IOError("Missing source ghuser: {}".format(src))

    shutil.copy(src, dst)
    print("Copied ghuser: {}".format(dst))

if _run:
    ghdoc = ghenv.Component.OnPingDocument()

    dewbee_source_dir = r"C:\Users\gzorzeto\AppData\Roaming\Grasshopper\UserObjects"
    dewbee_target_ghuser = r"C:\Users\gzorzeto\Documents\GitHub_repos\dewbee_main\grasshopper\user_objects"
    dewbee_target_py = r"C:\Users\gzorzeto\Documents\GitHub_repos\dewbee_main\grasshopper\src"

    with NamespaceComponentsOntoCanvas("DB", dewbee_source_dir, ghdoc) as compos:
        for compo in compos.compos:
            copy_ghuser(compo, dewbee_source_dir, dewbee_target_ghuser)
            copy_py_code(compo, dewbee_target_py)</item>
